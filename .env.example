# Instagram credentials (obrigatório)
INSTAGRAM_USERNAME=seu_usuario_instagram
INSTAGRAM_PASSWORD=sua_senha_instagram

# Proxy (opcional, mas recomendado para evitar bloqueio do Instagram)
# Formatos suportados:
#   http://ip:porta
#   http://usuario:senha@ip:porta
#   socks5://usuario:senha@ip:porta
PROXY_URL=
